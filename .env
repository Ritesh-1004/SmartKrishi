# =============================================================================
# SmartKrishi - AI Farming Advisor
# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# --- Flask Core ---
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your secret-flask-key
PORT=5000

# --- IBM watsonx.ai ---
IBM_CLOUD_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://au-syd.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-8b-code-instruct
WATSONX_EMBEDDING_MODEL=ibm/slate-125m-english-rtrvr-v2

# --- IBM IAM (Auto-generated, leave blank to auto-fetch) ---
IBM_IAM_TOKEN=

# --- Database ---
DATABASE_URL=sqlite:///smartkrishi.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/smartkrishi

# --- Vector Store (ChromaDB) ---
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=smartkrishi_knowledge

# --- Weather API (OpenWeatherMap) ---
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# --- Mandi Prices API (data.gov.in) ---
MANDI_API_KEY=your-data-gov-in-api-key
MANDI_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# --- Translation (LibreTranslate or Google Translate) ---
TRANSLATE_API_URL=https://libretranslate.com
TRANSLATE_API_KEY=your-libretranslate-api-key

# --- Redis (Session Cache & Rate Limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- Security & Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
MAX_CONTENT_LENGTH=16777216

# --- RAG Configuration ---
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# --- Agent Behavior ---
AGENT_MAX_TOKENS=1024
AGENT_TEMPERATURE=0.7
AGENT_LANGUAGE=en

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/smartkrishi.log
